# ─── AvantDrive ERP — Environment Variables ────────────────────

# Database (PostgreSQL 16)
DATABASE_URL=postgresql://avantdrive:avantdrive_secret@localhost:5432/avantdrive?schema=public
POSTGRES_DB=avantdrive
POSTGRES_USER=avantdrive
POSTGRES_PASSWORD=avantdrive_secret
POSTGRES_PORT=5432

# Redis 7
REDIS_URL=redis://:avantdrive_redis@localhost:6379
REDIS_PASSWORD=avantdrive_redis
REDIS_PORT=6379

# JWT Auth
JWT_SECRET=change-me-super-secret-key-at-least-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-key-at-least-32-chars
JWT_EXPIRATION=15m
REFRESH_EXPIRATION=7d

# API
PORT=3000
API_PORT=3000
CORS_ORIGIN=http://localhost:3001

# Node
NODE_ENV=development
